# ── Core ──────────────────────────────────────────────────
# Neon PostgreSQL connection string
NEON_DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Resend — transactional email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sales alert destination
SALES_ALERT_EMAIL=sales@voltsolenergy.com

# Admin dashboard password
ADMIN_PASSWORD=change_me

# Optional: display phone number site-wide (leave blank to hide)
VOLTSOL_PHONE=

# ── Marketplace — Stripe ───────────────────────────────────
# Stripe secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Stripe webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Stripe publishable key (safe for browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ── Marketplace — App ─────────────────────────────────────
# Secret used to sign marketplace session tokens (min 32 chars)
MARKETPLACE_SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# Base URL for email links (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://voltsolenergy.com
